# ─────────────────────────────────────────────
# CROWNED BEAUTY — ENVIRONMENT VARIABLES
# Copy this file to `.env` and fill in your values.
# Never commit `.env` to git!
# ─────────────────────────────────────────────

# Port the backend runs on (default 4000)
PORT=4000

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Cluster → Connect → Drivers
# Replace <password> with your DB user password
MONGODB_URI=mongodb+srv://username:<password>@cluster0.xxxxx.mongodb.net/crowned-beauty?retryWrites=true&w=majority

# JWT secret — used to sign admin login tokens
# Generate a strong random string (32+ chars). You can use: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_long_random_string

# Admin credentials — set these to whatever you want
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_in_production

# Cloudinary — for image and video uploads
# Free account at: https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Frontend URL (for CORS)
# In dev this is your local file. In production, your domain.
CLIENT_URL=http://localhost:3000
